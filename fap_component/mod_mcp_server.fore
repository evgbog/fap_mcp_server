// ф-я заполняет массив -  список фактов куба (ключ(ident), наименование).. берется версия (Destination) куба по умолчанию 
// возвращает признак успешности операции (TRUE/FALSE)
Public Function GetCubeFacts(CubeID: string; Var FactsList: array): boolean;
Var
	Cube: IStandardCube;
	CubeDest: IStandardCubeDestination;
	FactDimInst: IDimInstance;
	i: integer;
Begin
	Try
		// куб
		Cube := MetabaseClass.Active.ItemById(CubeID).Edit As IStandardCube;
		//
		{For Each CubeDest In Cube.Destinations Do
			If CubeDest.IsDefault Then
				Break;
			End If;
		End For;}
		For i := 0 To Cube.Destinations.Count-1 Do
			CubeDest := Cube.Destinations.Item(i);
			//Debug.WriteLine(CubeDest.Id + " " + CubeDest.Key.ToString + " " + CubeDest.IsDefault.ToString); 
			If CubeDest.IsDefault Then
				Break;
			End If;
		End For;
		// обрабатываем внутреннее измерение фактов
		FactDimInst := CubeDest.FactDimension.OpenDimension;
		If FactDimInst <> Null Then
			FactsList := New Variant[FactDimInst.Elements.Count, 2];
			// цикл по элементам
			For i := 0 To FactDimInst.Elements.Count-1 Do
				FactsList[i, 0] := FactDimInst.Elements.Id(i);
				FactsList[i, 1] := FactDimInst.Elements.Name(i);
			End For;
		End If;
		Return(True);
	Except On E: Exception Do
		Debug.WriteLine(E.Message);
		Return(False);
	End Try;
End Function GetCubeFacts;

// ф-я заполняет массив -  список измерений куба (кроме измерения фактов). Формирует массив  (id, наименование, признак_календарного). Берет Destination по умолчанию
// возвращает признак успешности операции (TRUE/FALSE)
Public Function GetCubeDimensions(CubeID: string; Var DimList: array): boolean;
Var
	Cube: IStandardCube;
	CubeDest: IStandardCubeDestination;
	i, idx: integer;
Begin
	Try
		// куб
		Cube := MetabaseClass.Active.ItemById(CubeID).Edit As IStandardCube;
		//
		For i := 0 To Cube.Destinations.Count-1 Do
			CubeDest := Cube.Destinations.Item(i);
			If CubeDest.IsDefault Then
				Break;
			End If;
		End For;
		//
		DimList := New Variant[CubeDest.Dimensions.Count-1, 3]; // на одно измерение меньше за счет фактового
		idx := 0;
		For i := 0 To CubeDest.Dimensions.Count-1 Do
			// пропустим фактовые измерения
			If CubeDest.Dimensions.Item(i).FactDimension Then
				Continue;
			End If;
			//
			DimList[idx, 0] := (CubeDest.Dimensions.Item(i).Dimension As IMetabaseObject).Id;
			DimList[idx, 1] := (CubeDest.Dimensions.Item(i).Dimension As IMetabaseObject).Name;
			DimList[idx, 2] := CubeDest.Dimensions.Item(i).Dimension.IsCalendar;
			idx := idx + 1;
		End For;
		Return(True);
	Except On E: Exception Do
		Debug.WriteLine(E.Message);
		Return(False);
	End Try;
End Function GetCubeDimensions;


