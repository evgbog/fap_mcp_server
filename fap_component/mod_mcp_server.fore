// пишем MCP-метаданные по заданному факту
Public Function MCP_WriteFactInfo(SourceID: string; FactID: variant; Name, Description, Aggregation, DataType, Format, Unit: string; Active: boolean): boolean;
Var
	Db: IDatabaseInstance;
	Command : IDalCommand;
	Params : IDalCommandParams;
	SQL: string;
Begin
	Try
		Db := MetabaseClass.Active.ItemById(DB_META).Open(Null) As IDatabaseInstance;
		// удаление
		SQL := "delete from mcp_facts where source_id = :src_id and id_s = :fact_id";
		Command := Db.Connection.CreateCommand(SQL);
		Command.Parse;
		Params := Command.Params;
		Params.Item(0).Value := SourceID;
		Params.Item(1).Value := FactID As String;
		Command.Execute;
		Command.Close;
		// вставка
		SQL := "insert into mcp_facts (source_id, id_s, id_n, name, description, aggregation, data_type, format, active, unit) values (:src_id, :fact_id_s, :fact_id_n, :name, :desc, :aggr, :datatype, :fmt, :active, :unit)";
		Command := Db.Connection.CreateCommand(SQL);
		Command.Parse;
		Params := Command.Params;
		Params.Item(0).Value := SourceID;
		Params.Item(1).Value := FactID As string;
		If FactID.VarType = ForeVariantType.Integer Then
			Params.Item(2).Value := FactID;
		End If;
		Params.Item(3).Value := Name;
		Params.Item(4).Value := Description;
		Params.Item(5).Value := Aggregation;
		Params.Item(6).Value := DataType;
		Params.Item(7).Value := Format;
		If Active Then
			Params.Item(8).Value := 1;
		Else			
			Params.Item(8).Value := 0;
		End If;
		Params.Item(9).Value := Unit;
		Command.Execute;
		Command.Close;
		Return(True);
	Except
		Return(False);
	End Try;
End Function MCP_WriteFactInfo;

// удаляем факт из MCP-метаданные 
Public Function MCP_DeleteFact(SourceID: string; FactID: variant; DeleteAll: boolean): boolean;
Var
	Db: IDatabaseInstance;
	Command : IDalCommand;
	Params : IDalCommandParams;
	SQL: string;
Begin
	Try
		Db := MetabaseClass.Active.ItemById(DB_META).Open(Null) As IDatabaseInstance;
		// удаление
		If DeleteAll Then
			SQL := "delete from mcp_facts where source_id = :src_id";
		Else	
			SQL := "delete from mcp_facts where source_id = :src_id and id_s = :fact_id";
		End If;
		Command := Db.Connection.CreateCommand(SQL);
		Command.Parse;
		Params := Command.Params;
		Params.Item(0).Value := SourceID;
		If Not DeleteAll Then
			Params.Item(1).Value := FactID As String;
		End If;
		Command.Execute;
		Command.Close;
		Return(True);
	Except
		Return(False);
	End Try;
End Function MCP_DeleteFact;

